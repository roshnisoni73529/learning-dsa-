class solution{
    int search (int arr[], int n,int num){
        
        for (int i = 0;i<n;i++){
            if (arr[i]==num)
            return i;
            
        }
        return -1;
    }
}
class Main {
    public static void main(String[] args) {
int arr[]={12,43,53,23,11};
int num=23;
int n= arr.length;
solution obj = new solution();
int val = obj.search(arr, n, num);
System.out.println(val);
return ;

    }
}
